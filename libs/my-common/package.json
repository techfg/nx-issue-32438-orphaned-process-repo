{
  "name": "@nx-issue-repro/my-common",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@nx-issue-repro/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/my-common/dist",
          "main": "libs/my-common/src/index.ts",
          "tsConfig": "libs/my-common/tsconfig.lib.json",
          "format": [
            "esm"
          ],
          "declarationRootDir": "libs/my-common/src"
        }
      }
    },
    "tags": ["type:backend-dep"],
    "implicitDependencies": ["cli"]
  },
  "dependencies": {}
}
