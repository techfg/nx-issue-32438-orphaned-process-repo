{
  "name": "backend-go",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/backend-go",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["golang", "default", "^production", "sharedGlobals"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "command": "mkdir -p ./dist && go build -o {args.outputPath} ./main.go",
        "cwd": "{projectRoot}",
        "outputPath": "./dist/backend-go"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "go run ./main.go",
        "cwd": "{projectRoot}"
      }
    },
    "serve-dist": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "./dist/backend-go",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        "build",
        { "projects": "tag:type:backend-dep", "target": "build" }
      ]
    },
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "bash ./scripts/dev.sh",
        "cwd": "{projectRoot}"        
      },
      "dependsOn": [
        "build",
        { "projects": "tag:type:backend-dep", "target": "build" },
        "start-deps"
      ]
    },
    "start-deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.yaml up -d --wait",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}