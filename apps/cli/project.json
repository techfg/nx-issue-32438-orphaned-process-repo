{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cli",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p ./dist && go build -o {args.outputPath} ./main.go",
        "cwd": "{projectRoot}",
        "outputPath": "./dist/cli"
      },
      "inputs": [
        "golang",
        "default",
        "^production",
        "sharedGlobals",
        { "projects": ["backend-go"], "input": "golang" }
      ],
      "outputs": ["{options.outputPath}"]      
    }
  }
}